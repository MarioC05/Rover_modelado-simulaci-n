<?xml version="1.0"?>

<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="rover_wheel" params="prefix parent *origin">

    <joint name="${prefix}link_joint" type="continuous">
        <limit effort="100.00000" velocity="10.00000"/>
        <xacro:insert_block name="origin"/>
        <parent link="${parent}"/>
        <child link="${prefix}link"/>
        <axis xyz="0.00000 0.00000 1.00000"/>
    </joint>

    <link name="${prefix}link">
        <collision name="${prefix}collision">
            <origin rpy="0.00000 0.00000 0.00000" xyz="0.00000 0.00000 -0.00000"/>
            <geometry>
                <mesh filename="package://rover_description/meshes/dae/Torus.011.dae" scale="1.00000 1.00000 1.00000"/>
            </geometry>
            <surface>
                <friction>
                    <ode>
                        <mu>1.000000</mu>
                        <mu2>1.000000</mu2>
                        <fdir1>0.000000 0.000000 1.000000</fdir1>
                    </ode>
                </friction>
            </surface>
        </collision>
        <inertial>
            <inertia ixx="0.03721" ixy="0.00000" ixz="0.00000" iyy="0.06912" iyz="0.00000" izz="0.03682"/>
            <origin rpy="0.00000 0.00000 0.00000" xyz="0.00000 0.00000 -0.00809"/>
            <mass value="1.00000"/>
        </inertial>
        <visual name="${prefix}">
            <material name="Material.001"/>
            <origin rpy="0.00000 0.00000 0.00000" xyz="0.00000 0.00000 -0.00172"/>
            <geometry>
                <mesh filename="package://rover_description/meshes/dae/Torus.004.dae" scale="0.32000 0.32000 0.38433"/>
            </geometry>
        </visual>
    </link>

    <!-- Transmission is important to link the joints and the controller (see config/rover_controller.yaml)-->
    <transmission name="${prefix}_wheel_joint_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="${prefix}wheel_joint" >
            <hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface>
        </joint>
        <actuator name="${prefix}wheel_joint_motor">
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>

    <gazebo reference="${prefix}wheel_link">
        <mu1>5</mu1>
        <mu2>5</mu2>
    </gazebo>

  </xacro:macro>

</robot>